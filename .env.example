# .env.example — LLMUI Core
# Copyright © Technologies Nexios TF Inc. — nexiostf.com
#
# ⚠️  Ce fichier contient UNIQUEMENT les informations de démarrage initial.
#     Toute autre configuration appartient à PostgreSQL, gérée via /zadmin.
#     Ne jamais ajouter d'autres variables ici — voir STANDARDS.md §2.

# Connexion PostgreSQL — point de départ uniquement
DATABASE_URL=postgresql+asyncpg://llmui_user:CHANGEME@localhost:5432/llmui_core

# Port de l'application FastAPI (plage 8000-8999, défaut 8004)
APP_PORT=8004

# Environnement (development | production)
APP_ENV=production
