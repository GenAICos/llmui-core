# Redirection HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};
    return 301 https://$host$request_uri;
}

# HTTPS + Reverse proxy → Uvicorn 127.0.0.1:{{ app_port }}
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    # ── SSL Let's Encrypt (géré par certbot) ─────────────────────────
    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # ── Headers de sécurité ───────────────────────────────────────────
    add_header Strict-Transport-Security  "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options            "DENY" always;
    add_header X-Content-Type-Options     "nosniff" always;
    add_header X-XSS-Protection           "1; mode=block" always;
    add_header Referrer-Policy            "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy         "geolocation=(), microphone=(), camera=()" always;

    # ── Logs ─────────────────────────────────────────────────────────
    access_log /var/log/nginx/financefamille.access.log;
    error_log  /var/log/nginx/financefamille.error.log warn;

    # ── Fichiers statiques ────────────────────────────────────────────
    location /static/ {
        alias   {{ install_dir }}/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location = /favicon.ico {
        alias   {{ install_dir }}/static/favicon.ico;
        access_log off;
        log_not_found off;
    }

    # ── Ollama pull (timeout long — téléchargement de modèles) ────────
    location = /zadmin/api/ollama-pull {
        proxy_pass          http://127.0.0.1:{{ app_port }};
        proxy_http_version  1.1;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_connect_timeout   10s;
        proxy_read_timeout      630s;
        proxy_send_timeout      630s;
        client_max_body_size    1M;
    }

    # ── Reverse proxy → Uvicorn ───────────────────────────────────────
    location / {
        proxy_pass          http://127.0.0.1:{{ app_port }};
        proxy_http_version  1.1;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_set_header    X-Forwarded-Host  $host;
        proxy_set_header    Upgrade    $http_upgrade;
        proxy_set_header    Connection "upgrade";
        proxy_connect_timeout   10s;
        proxy_read_timeout      60s;
        proxy_send_timeout      60s;
        client_max_body_size    5M;
        proxy_buffering         off;
    }

    # ── Healthcheck (local uniquement) ────────────────────────────────
    location = /health {
        proxy_pass http://127.0.0.1:{{ app_port }}/health;
        allow 127.0.0.1;
        deny all;
    }
}
